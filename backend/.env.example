# ── API Keys ─────────────────────────────────────────────────────────────────
# CoinGecko Pro key (leave blank to use free tier — rate limited)
COINGECKO_API_KEY=

# Optional sentiment data sources
CRYPTOPANIC_TOKEN=
NEWSAPI_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# LOCAL:      http://localhost:5173,http://localhost:3000
# PRODUCTION: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ── Model settings (optional — defaults shown) ────────────────────────────────
WINDOW=60
EPOCHS=150
OPTUNA_TRIALS=20
RUN_OPTUNA=true
ENABLE_PROPHET=true
ENABLE_SARIMA=true
ENABLE_LSTM=true
ENABLE_TRANSFORMER=true

# ── Storage ───────────────────────────────────────────────────────────────────
# Path to folder containing data_pipeline.py, model_training.py, and CSVs
DATA_DIR=./data
CACHE_DIR=.cache
MODEL_CACHE_DIR=.model_cache
